PORT=8787
SCHEDULE_ENABLED=true
SCHEDULE_INTERVAL_MINUTES=5
LIVE_STAGE=dry-run
DRY_RUN=true
AUTOSTART_OPEN_BROWSER_PWA=true
AUTOSTART_PWA_URL=http://127.0.0.1:8787
CLOUDFLARE_TUNNEL_TARGET_URL=http://127.0.0.1:8787
BOT_UV_THREADPOOL_SIZE=16
BOT_GPU_ENABLED=true
EXECUTION_PROVIDER=okx-agentic-wallet
ONCHAINOS_BIN=/home/lasbonai/.local/bin/onchainos

# OpenAI-compatible LLM endpoint.
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11435/v1
OPENAI_MODEL=lasbonai-trading
# Optional OpenClaw gateway token. Set this when using OpenClaw and the endpoint returns 401 Unauthorized.
OPENCLAW_GATEWAY_TOKEN=

# OKX DEX API credentials.
# Optional when the bot uses the local Onchain OS CLI fallback for quote/build.
OKX_DEX_BASE_URL=https://web3.okx.com
OKX_ACCESS_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# Execution wallet.
# Required by the CLI runner because it becomes the request walletAddress.
EXECUTION_WALLET_PRIVATE_KEY=
EXECUTION_WALLET_ADDRESS=
EVM_RPC_URL=

# OKX Agentic Wallet execution bridge.
# Use this mode when a server-side OKX Agentic Wallet executor is available.
OKX_AGENTIC_WALLET_EXECUTE_URL=
OKX_AGENTIC_WALLET_API_KEY=
OKX_AGENTIC_WALLET_ID=
OKX_AGENTIC_SUB_WALLET_ID=

# XRPL native execution bridge.
# Point XRPL_NATIVE_EXECUTE_URL to your real executor endpoint for live XRPL submission.
# For local end-to-end simulation only, enable mock and set URL to:
#   http://127.0.0.1:8787/api/xrpl/executor/mock
XRPL_NATIVE_EXECUTE_URL=
XRPL_NATIVE_EXECUTE_API_KEY=
XRPL_NATIVE_EXECUTE_WALLET=
XRPL_NATIVE_EXECUTE_TIMEOUT_MS=25000
XRPL_NATIVE_EXECUTE_MOCK_ENABLED=false
# Comma-separated allowlist for executor hostnames.
# Required when LIVE_STAGE=full. Example: xrpl-exec.mycompany.com
XRPL_NATIVE_EXECUTE_ALLOWED_HOSTS=

# Optional CLI defaults.
DEFAULT_CHAIN_ID=1
DEFAULT_BASE_TOKEN_ADDRESS=
DEFAULT_QUOTE_TOKEN_ADDRESS=
DEFAULT_BUY_AMOUNT=
DEFAULT_SELL_AMOUNT=
DEFAULT_SLIPPAGE=0.5
DEFAULT_MARKET_CONTEXT=Automated 5-minute scan for conservative opportunities.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USERNAME=@lasbon_88

CANDIDATE_SCAN_ENABLED=true
CANDIDATE_NOTIFY_ONLY_WHEN_FOUND=true
CANDIDATE_CHAIN=bnb
CANDIDATE_ALLOWLIST_ADDRESSES=
CANDIDATE_ALLOWLIST_FALLBACK_TO_TOP=true
CANDIDATE_RISK_FILTER=false
CANDIDATE_STABLE_FILTER=false
CANDIDATE_LIMIT=10
CANDIDATE_HOLDERS_MIN=500000
CANDIDATE_LIQ_MIN_IDR=10000000
CANDIDATE_MC_MIN_IDR=10000000000000
CANDIDATE_FDV_MIN_IDR=0
CANDIDATE_AUTO_RELAX_ENABLED=true
CANDIDATE_RELAX_HOLDERS_MIN=100000
CANDIDATE_RELAX_MC_MIN_IDR=340000000000
CANDIDATE_RELAX_FDV_MIN_IDR=0
CANDIDATE_FX_USD_TO_IDR=0
CANDIDATE_REQUIRE_EXPLICIT_FDV=false
CANDIDATE_SCAN_MAX_ATTEMPTS=3
CANDIDATE_SCAN_RETRY_DELAY_MS=10000
CANDIDATE_HISTORY_ENABLED=true
CANDIDATE_HISTORY_KEEP=576

# Risk controls.
MAX_CONFIDENCE_TO_EXECUTE=0.65
MAX_BUY_AMOUNT=
MAX_SELL_AMOUNT=

# Google OAuth – MCP default gateway
GOOGLE_CLIENT_ID=204421016317-9fnkralojtes0u7lv0skua2spnm9j3u8.apps.googleusercontent.com